{
  "name": "Stack Template",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-22-bookworm",
  "containerEnv": {
    "NODE_ENV": "development"
  },
  "postCreateCommand": "npm install -g @anthropic-ai/claude-code && curl -Ls --tlsv1.2 --proto '=https' --retry 3 https://cli.doppler.com/install.sh | sh",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "forwardPorts": [5173],
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ]
    }
  }
}
